<Window x:Class="WpfInchirieri.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inchirieri Auto" Height="520" Width="850"
        Background="#E6CCFF">

    <Window.Resources>

        <!-- BUTOANE -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#B266FF"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#6600CC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- LABEL -->
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5,10,5,2"/>
        </Style>

        <!-- HEADER TABEL -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#B266FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- RANDURI TABEL -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#E6CCFF"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2E6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENIU -->
        <Border Grid.Row="0"
                Background="#B266FF"
                CornerRadius="10"
                Padding="5"
                Width="320"
                HorizontalAlignment="Left"
                Margin="0,0,0,10">

            <Menu Background="Transparent">
                <MenuItem Header="Fisier">
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </MenuItem>

                <MenuItem Header="Meniu">
                    <MenuItem Header="Adauga" Click="FocusAdd"/>
                    <MenuItem Header="Cautare" Click="FocusCautare"/>
                </MenuItem>

                <MenuItem Header="Ajutor">
                    <MenuItem Header="Despre" Click="Despre_Click"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- CONTINUT -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FORMULAR -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">

                <Border Background="#F2E6FF" CornerRadius="15" Padding="10">

                    <StackPanel>

                        <TextBlock Text="Adaugare masina" FontSize="18" HorizontalAlignment="Center"/>

                        <TextBlock x:Name="lblMarca" Text="Marca"/>
                        <TextBox x:Name="txtMarca"/>

                        <TextBlock x:Name="lblModel" Text="Model"/>
                        <TextBox x:Name="txtModel"/>

                        <TextBlock x:Name="lblAn" Text="An"/>
                        <TextBox x:Name="txtAn"/>

                        <TextBlock Text="Culoare"/>
                        <ComboBox x:Name="cbCuloare" Height="28"/>

                        <TextBlock Text="Optiuni"/>

                        <CheckBox x:Name="chkTrapa" Content="Trapa panoramica"/>
                        <CheckBox x:Name="chkNav" Content="Navigatie"/>
                        <CheckBox x:Name="chkSuspensie" Content="Suspensie reglabila"/>
                        <CheckBox x:Name="chkIncalzire" Content="Incalzire scaune"/>
                        <CheckBox x:Name="chkSenzori" Content="Senzori parcare"/>

                        <TextBlock Text="Tip transmisie"/>

                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rbManual" Content="Manuala" IsChecked="True" Margin="5"/>
                            <RadioButton x:Name="rbAutomat" Content="Automata" Margin="5"/>
                        </StackPanel>

                        <Button Content="Adauga masina" Click="AdaugaMasina_Click"/>

                        <TextBlock Text="Cautare dupa marca"/>

                        <StackPanel Margin="5">

                            <TextBox x:Name="txtCautareMarca" Height="30" Margin="0,0,0,8"/>

                            <Button Content="Cauta" Click="CautaMasina_Click" Height="35" Width="280" Margin="0,0,0,5"/>

                            <Button Content="Reset" Click="ReseteazaLista_Click" Height="35" Width="280" Margin="0,0,0,5"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

            </ScrollViewer>

            <!-- TABEL -->
            <DataGrid x:Name="dgMasini"
                      Grid.Column="1"
                      Margin="10"
                      AutoGenerateColumns="False"
                      RowHeight="35"
                      CanUserAddRows="False"
                      AlternationCount="2"
                      RowStyle="{StaticResource RowStyle}"
                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                      AlternatingRowBackground="#F2E6FF"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Marca" Binding="{Binding Marca}" Width="120"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120"/>
                    <DataGridTextColumn Header="An" Binding="{Binding An}" Width="80"/>
                    <DataGridTextColumn Header="Culoare" Binding="{Binding CuloareMasina}" Width="120"/>

                    <DataGridTextColumn Header="Optiuni" Binding="{Binding OptiuniMasina}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Disponibil" Binding="{Binding Disponibila}" Width="100"/>
                    <DataGridTextColumn Header="Transmisie" Binding="{Binding Transmisie}" Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </Grid>

    </Grid>
</Window>