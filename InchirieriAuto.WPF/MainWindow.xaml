<Window x:Class="WpfInchirieri.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inchirieri Auto" Height="450" Width="800"
        Background="#E6CCFF">
    <!-- mov lila -->

    <Window.Resources>

        <!-- Stil pentru butoane -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#B266FF"/>
            <!-- mov -->
            <Setter Property="Foreground" Value="Black"/>
            <!-- text negru -->
            <Setter Property="BorderBrush" Value="#6600CC"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Zona de butoane -->
        <StackPanel Orientation="Horizontal" Grid.Row="0">

            <Button Content="Incarca masini" Click="Reload_Click"/>
            <Button Content="Afiseaza mesaj"/>

        </StackPanel>

        <!-- Tabel masini -->
        <DataGrid x:Name="dgMasini"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  Background="White"
                  RowBackground="#F2E6FF"
                  AlternatingRowBackground="#E0CCFF"
                  FontSize="14"
                  Margin="0,10,0,0">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#9933FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Marca" Binding="{Binding Marca}" />
                <DataGridTextColumn Header="Model" Binding="{Binding Model}" />
                <DataGridTextColumn Header="An" Binding="{Binding An}" />
                <DataGridTextColumn Header="Culoare" Binding="{Binding CuloareMasina}" />
                <DataGridTextColumn Header="Optiuni" Binding="{Binding OptiuniMasina}" />
                <DataGridTextColumn Header="Disponibil" Binding="{Binding Disponibila}" />
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
